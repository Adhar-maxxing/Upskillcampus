    {
        "id": "9a53dd82d868677a",
        "type": "function",
        "z": "8151e0190ca9ce99",
        "name": "Calculate Average Power",
        "func": "let totalPower = flow.get(\"totalPower\") || 0;\nlet powerCount = flow.get(\"powerCount\") || 0;\n\ntotalPower += msg.payload.power;\npowerCount += 1;\n\nflow.set(\"totalPower\", totalPower);\nflow.set(\"powerCount\", powerCount);\n\nlet averagePower = totalPower / powerCount;\n\nmsg.payload = averagePower.toFixed(2) + \" W\";\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
