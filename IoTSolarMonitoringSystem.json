    {
        "id": "76ba225239afde3f",
        "type": "function",
        "z": "8151e0190ca9ce99",
        "name": "Count Faults",
        "func": "let faultCount = flow.get(\"faultCount\") || 0;\nlet previousFault = flow.get(\"previousFault\") || \"NORMAL\";\n\nif (\n    previousFault === \"NORMAL\" &&\n    msg.payload.fault === \"FAULT\"\n) {\n    faultCount += 1;\n}\n\nflow.set(\"faultCount\", faultCount);\nflow.set(\"previousFault\", msg.payload.fault);\n\nmsg.payload = faultCount;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
