    {
        "id": "a60b929c2b017df5",
        "type": "function",
        "z": "8151e0190ca9ce99",
        "name": "Calculate System Uptime",
        "func": "let totalPackets = flow.get(\"totalPackets\") || 0;\nlet healthyPackets = flow.get(\"healthyPackets\") || 0;\n\ntotalPackets++;\n\nif (msg.payload.fault === \"NORMAL\") {\n    healthyPackets++;\n}\n\nflow.set(\"totalPackets\", totalPackets);\nflow.set(\"healthyPackets\", healthyPackets);\n\nlet uptime = (healthyPackets / totalPackets) * 100;\n\nmsg.payload = uptime.toFixed(2) + \" %\";\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
