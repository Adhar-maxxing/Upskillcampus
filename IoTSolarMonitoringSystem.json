    {
        "id": "e7d5a462e639bc19",
        "type": "function",
        "z": "8151e0190ca9ce99",
        "name": "Generate Solar Data",
        "func": "let voltage = 18 + Math.random() * 4;\nlet current = 3 + Math.random() * 2;\nlet power = voltage * current;\nlet temperature = 28 + Math.random() * 16;\nlet battery_voltage = 11 + Math.random() * 2;\nlet efficiency = 75 + Math.random() * 20;\n\nmsg.payload = {\n    voltage: Number(voltage.toFixed(2)),\n    current: Number(current.toFixed(2)),\n    power: Number(power.toFixed(2)),\n    temperature: Number(temperature.toFixed(2)),\n    battery_voltage: Number(battery_voltage.toFixed(2)),\n    efficiency: Number(efficiency.toFixed(2)),\n    timestamp: new Date().toISOString()\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 420,
