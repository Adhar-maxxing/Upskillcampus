    {
        "id": "74bde12c207afb77",
        "type": "function",
        "z": "8151e0190ca9ce99",
        "name": "Validate & Analyze Data",
        "func": "let data = msg.payload;\n\nif (\n    data.voltage === undefined ||\n    data.current === undefined ||\n    data.power === undefined ||\n    data.temperature === undefined\n) {\n    return null;\n}\n\nconst thresholds = {\n    voltage: {\n        warning_low: 17.5,\n        critical_low: 17\n    },\n\n    temperature: {\n        warning_high: 40,\n        critical_high: 45\n    },\n\n    battery_voltage: {\n        warning_low: 11.2,\n        critical_low: 10.8\n    }\n};\n\ndata.alerts = [];\nif (data.voltage < thresholds.voltage.critical_low) {\n    data.alerts.push(\"CRITICAL LOW VOLTAGE\");\n}\nelse if (data.voltage < thresholds.voltage.warning_low) {\n    data.alerts.push(\"LOW VOLTAGE WARNING\");\n}\nif (data.temperature > thresholds.temperature.critical_high) {\n    data.alerts.push(\"CRITICAL HIGH TEMPERATURE\");\n}\nelse if (data.temperature > thresholds.temperature.warning_high) {\n    data.alerts.push(\"HIGH TEMPERATURE WARNING\");\n}\nif (data.battery_voltage < thresholds.battery_voltage.critical_low) {\n    data.alerts.push(\"CRITICAL LOW BATTERY\");\n}\nelse if (data.battery_voltage < thresholds.battery_voltage.warning_low) {\n    data.alerts.push(\"LOW BATTERY WARNING\");\n}\nif (data.alerts.length > 0) {\n    data.fault = \"FAULT\";\n}\nelse {\n    data.fault = \"NORMAL\";\n}\n\nmsg.payload = data;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 430,
        "y": 220,
        "wires": [
